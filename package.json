{
  "name": "bureau-mcp",
  "version": "0.1.0",
  "description": "MCP server that exposes a folder-based personal virtual organization (departments / TODOs / notes) to Claude. Bring your own .company/-style folder.",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@10.30.3",
  "bin": {
    "bureau-mcp": "./dist/index.js"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "build": "esbuild src/index.ts --bundle --platform=node --format=esm --target=node20 --packages=external --outfile=dist/index.js --banner:js=\"#!/usr/bin/env node\" && chmod +x dist/index.js",
    "start": "node dist/index.js",
    "test": "vitest run",
    "inspect": "npx @modelcontextprotocol/inspector tsx src/index.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.18.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "esbuild": "^0.24.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
